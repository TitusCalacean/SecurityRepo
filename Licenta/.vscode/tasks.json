{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build capture",
            "type": "shell",
            "command": "C:/MinGW/bin/gcc.exe",
            "args": [
                "${workspaceFolder}/capture.c",
                "-I${workspaceFolder}/Include",
                "-L${workspaceFolder}/Lib/x64",
                "-lwpcap",
                "-lPacket",
                "-lws2_32",
                "-o",
                "${workspaceFolder}/capture.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}